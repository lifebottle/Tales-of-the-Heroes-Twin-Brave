      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>30</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>５０秒以内に敵を全滅させろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>門番出現！　倒して先へ進め！</JapaneseText>
      <EnglishText>The Gatekeeper has appeared! Defeat him and move forward!</EnglishText>
      <Notes/>
