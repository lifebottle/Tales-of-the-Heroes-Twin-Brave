      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>64</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ボーナス宝箱出現！</JapaneseText>
      <EnglishText>A bonus treasure chest has appeared!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>65</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>先へ進め！</JapaneseText>
      <EnglishText>Press on!</EnglishText>
      <Notes/>
