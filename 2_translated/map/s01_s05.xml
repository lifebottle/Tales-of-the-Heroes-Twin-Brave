      <JapaneseText>２０秒以内に門番を倒せ！</JapaneseText>
      <EnglishText>Defeat the Gatekeeper within 20 seconds!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>58</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ボーナス宝箱出現！</JapaneseText>
      <EnglishText>A bonus treasure chest has appeared!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>59</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>先へ進め！</JapaneseText>
      <EnglishText>Press on!</EnglishText>
      <Notes/>
