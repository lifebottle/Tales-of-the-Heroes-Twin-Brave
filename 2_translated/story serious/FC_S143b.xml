<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>アスベル</JapaneseText>
      <EnglishText>Asbel</EnglishText>
      <Notes/>
      <Id>28</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>シェリア</JapaneseText>
      <EnglishText>Cheria</EnglishText>
      <Notes/>
      <Id>29</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>シェリア、大丈夫か？</JapaneseText>
      <EnglishText>Cheria, are you alright?</EnglishText>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ええ、なんとか</JapaneseText>
      <EnglishText>Yes, somehow.</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうか……よかった……ぐっ……</JapaneseText>
      <EnglishText>I see... I'm glad... Ugh...</EnglishText>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>アスベル……アスベル！！
あっ、いつの間にこんな傷を……！</JapaneseText>
      <EnglishText>Asbel... Asbel!!
Ah, when did you get such a horrible wound...?!</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え？</JapaneseText>
      <EnglishText>Huh?</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺はちゃんと……シェリアを守れたんだな</JapaneseText>
      <EnglishText>I was able... to protect you properly.</EnglishText>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>…………！</JapaneseText>
      <EnglishText>...!</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>バカ！！
こんなときになに言ってるのよ！</JapaneseText>
      <EnglishText>You dummy!
What are you saying that for at a time like this?!</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんまり怒鳴らないでくれ。
傷口に響く……</JapaneseText>
      <EnglishText>Don't yell so loud.
I can feel it right through my wound...</EnglishText>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>アスベル……あなたは……バカだわ</JapaneseText>
      <EnglishText>Asbel... You really are... such an idiot.</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
