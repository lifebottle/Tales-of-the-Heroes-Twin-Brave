<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヴェイグ</JapaneseText>
      <EnglishText>Veigue</EnglishText>
      <Notes/>
      <Id>12</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ティトレイ</JapaneseText>
      <EnglishText>Tytree</EnglishText>
      <Notes/>
      <Id>13</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……すまない、ティトレイ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ん？　おれはなんにも気にしてねぇぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さぁて、めんどくせぇ追っ手が来ないウチに
ちゃっちゃと行こうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹は、もう遠くないはずだしよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ティトレイ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ん？　なんだよ、ヴェイグ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>お前を巻き込んでしまったな。
すまない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>またかよ。
つまんねぇ事気にすんなって！
仲間なんだから当然だろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんだよ？
黙ってちゃわかんねぇぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレは……お前のようにはなれない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんだよ、それ？
意味わかんねぇ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>けど、ヴェイグは
ヴェイグのままでいいんじゃねぇか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>お前がおれになっちゃったら、
おれがふたりいて意味わかんねぇしよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……そうか。　そうだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
