<SceneText>
  <FriendlyName>Chapter 3 (Spada) - End</FriendlyName>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>シェリア</JapaneseText>
      <EnglishText>Cheria</EnglishText>
      <Notes/>
      <Id>29</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ルカ</JapaneseText>
      <EnglishText>Ruca</EnglishText>
      <Notes/>
      <Id>20</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>スパーダ</JapaneseText>
      <EnglishText>Spada</EnglishText>
      <Notes/>
      <Id>21</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>クロエ</JapaneseText>
      <EnglishText>Chloe</EnglishText>
      <Notes/>
      <Id>15</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これで……どう？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ありがとうございます！
すごく楽になったよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>んだよ！
薬なんてあんなら
最初っからよこせっつーの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この薬には疫病を治す力はないわ。
ただ痛みや辛さを一時的に和らげるだけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>身体をだましているにすぎない
……そういう事か？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ええ。
だからあなたの病状は
まったく改善されてはいないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……そうなんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でもありがとう。
これで僕はまだやれるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうせ言っても聞かないんでしょ？
だったら、身体の負担くらいは
減らしてあげないとね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ただそれでも……無茶はしないで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>へっ！
そいつぁ約束できねェなぁ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんだと？
貴公はミルダが心配ではないのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>心配なんざしてねェよ。
ルカはオレが守るからだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>スパーダ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>決めたぜ、ルカ！
オレはお前の剣となり、お前の敵を討つ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>お前の意志には
そんだけのが価値あるって認めてやるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ありがとう、スパーダ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ただしオレは暴れるぜェ。
ちゃんと使いこなせねぇとなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
