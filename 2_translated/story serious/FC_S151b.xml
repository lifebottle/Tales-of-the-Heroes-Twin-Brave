<SceneText>
  <FriendlyName>Chapter 1 (Jude) - End</FriendlyName>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ジュード</JapaneseText>
      <EnglishText>Jude</EnglishText>
      <Notes/>
      <Id>30</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミラ</JapaneseText>
      <EnglishText>Milla</EnglishText>
      <Notes/>
      <Id>31</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>大丈夫なのかな、エミル……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>精霊達の力により精製した
ラタトスクを抑え込む
腕輪を渡しておいた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これで少なくとも
ラタトスクへの変身の負担が
身体を蝕む事はなくなるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ラタトスクも精霊なんだよね？
なにがそんなに危険なの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうやら精霊ラタトスクは
人間に強い恨みを抱いているようだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いったいどうして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ラタトスクには
かつて一人だけ心を許せる友がいたそうだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それが、命を司る精霊</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だから許せないのだろうな。
友の犠牲により救われた世界を踏み荒らす
人間という存在が</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>犠牲？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>行こうか。　時間が惜しい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>私は、一刻も早く
世界樹を救わねばならないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ねえ、ミラはどうしてそこまで
世界樹を救う事にこだわるの？
精霊に頼まれたから？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その通りだ。
私は精霊達と約束した。
必ず世界樹を救ってみせると</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これは、私の使命なんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>使命……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
