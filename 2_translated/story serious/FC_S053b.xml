    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゼロス</JapaneseText>
      <EnglishText>Zelos</EnglishText>
      <Notes/>
      <Id>11</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミラ</JapaneseText>
      <EnglishText>Milla</EnglishText>
      <Notes/>
      <Id>31</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ジュード</JapaneseText>
      <EnglishText>Jude</EnglishText>
      <Notes/>
      <Id>30</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゼロス、お前はどうか知らないけど
俺はお前の事、仲間だと思ってる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だから話してくれ！
世界樹を壊す理由
本当は他にもあるんじゃないのかよ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなもんねぇよ。
俺さまはただ、神子から解放されたいだけさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゼロス！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>見つけたぞ、神子ゼロス</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>誰だ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あなたを止めに来ました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>精霊達が教えてくれたんだ。
世界樹に迫る危険をな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>神子ゼロス、一緒に来てもらうぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>へぇ。　デートの誘いかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹の異変の理由
お前なら知っているはずだ。
それを聞かせてもらう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>素直に話すかな？
俺さまけっこう口堅いのよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……行くぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゼロス……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>じゃあな、ロイド</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゼロス、俺は……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
