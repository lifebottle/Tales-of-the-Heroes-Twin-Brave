    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エルレイン</JapaneseText>
      <EnglishText>Elraine</EnglishText>
      <Notes/>
      <Id>34</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エルレイン！！　どこだ！　どこにいる！！</JapaneseText>
      <EnglishText>Elraine!! Where are you?!
Where the heck are you?!!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あなたのおかげで予定が狂ってしまいました</JapaneseText>
      <EnglishText>My plans have gone all wrong because of you.</EnglishText>
      <Notes/>
      <SpeakerId>34</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>リオンにはまだ役目が残っていたのに</JapaneseText>
      <EnglishText>Leon still had a role left to play.</EnglishText>
      <Notes/>
      <SpeakerId>34</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エターナルソードを使い、世界を作り替えるという役目が</JapaneseText>
      <EnglishText>The role of using the Eternal Sword
to remake the world.</EnglishText>
      <Notes/>
      <SpeakerId>34</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>黙れ！　お前だけは絶対に許さないぞ！</JapaneseText>
      <EnglishText>Shut up! No chance in hell I'll ever forgive you!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
