    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミラ</JapaneseText>
      <EnglishText>Milla</EnglishText>
      <Notes/>
      <Id>31</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>シング</JapaneseText>
      <EnglishText>Shing</EnglishText>
      <Notes/>
      <Id>26</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>コハク</JapaneseText>
      <EnglishText>Kohaku</EnglishText>
      <Notes/>
      <Id>27</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>痛っ……！</JapaneseText>
      <EnglishText>Ow...!</EnglishText>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>怪我をしたのか、ジュード。
ならこれを塗ってみるといい</JapaneseText>
      <EnglishText>Are you hurt, Jude?
Put this on it.</EnglishText>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え？　それ……ミソ？</JapaneseText>
      <EnglishText>Huh? Is that... miso?</EnglishText>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>香りがいい。
きっと傷口にも効くはずだ</JapaneseText>
      <EnglishText>It has a nice smell to it.
I'm sure it's effective on wounds.</EnglishText>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え？　えぇ？</JapaneseText>
      <EnglishText>Huh? What?</EnglishText>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>コハク、今の見た？</JapaneseText>
      <EnglishText>Kohaku, did you see that?</EnglishText>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>傷口にミソを塗るなんて信じられない！</JapaneseText>
      <EnglishText>I can't believe she just put miso
on someone's wound!</EnglishText>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でも傷口に塗ったあと
そこを舐めればちょっとおいしいね！</JapaneseText>
      <EnglishText>Though, if you lick the wound after putting
that on, the wound would taste kinda good!</EnglishText>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
