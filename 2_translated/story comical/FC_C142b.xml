  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これに懲りたら
二度と覗きなんて卑劣な真似はしないことだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>へ〜い</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>はぁ、俺さま反省。
これくらいでこんなに痛い目にあわされちゃ
割に合わないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>反省が見られないわね。
なんなら縛りあげた状態で
女の子達に引き渡そうかしら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うっげェェェ！　それマジ勘弁！
タコ殴り確実じゃねェか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わかった、もうしません！
もうしませんから〜！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうか。　わかればいいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やったわね、アスベル</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ああ。
俺は、女性を守れたんだな……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>28</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
