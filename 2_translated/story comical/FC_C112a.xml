<SceneText>
  <FriendlyName>Chapter 2 (Marta) - Start</FriendlyName>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マルタ</JapaneseText>
      <EnglishText>Marta</EnglishText>
      <Notes/>
      <Id>23</Id>
