  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺さま　イズ　イノセンス！　なんつって！</JapaneseText>
      <EnglishText>I am Innocence!
Just kidding!</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マジでこんな奴が主人公になんのかよ。
ありえねェ……</JapaneseText>
      <EnglishText>Is this dude seriously gonna be the protag?
No goddamn way...</EnglishText>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それがありえちゃうのよねぇ</JapaneseText>
      <EnglishText>Yes goddamn waaay.</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの、その……</JapaneseText>
      <EnglishText>Um, so...</EnglishText>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうしたんだ、ルカ？</JapaneseText>
      <EnglishText>What's up, Ruca?</EnglishText>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>負けちゃったんで、主人公は譲るよ。
だからさ……</JapaneseText>
      <EnglishText>I lost, so I have to give up the lead role.
So...</EnglishText>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ホットドッグ買ってきてくれない？</JapaneseText>
      <EnglishText>Will you go buy me a hotdog?</EnglishText>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>はぁ？　なんで俺さま！？</JapaneseText>
      <EnglishText>Huh? Why me?!</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>知らねェのかよ？
イノセンスの主人公は
ホットドッグ買いにいかされんだぜ</JapaneseText>
      <EnglishText>Don't you know your stuff?
Innocence's protag has to
go out and buy hotdogs.</EnglishText>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>んなっ！！！？</JapaneseText>
      <EnglishText>Wha--?!!!</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>嫌だ！
俺さまパシリなんてゴメンだね！</JapaneseText>
      <EnglishText>Heck no! I'm not gonna run around doing errands!</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
