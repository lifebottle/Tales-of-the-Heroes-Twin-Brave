      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ルビア</JapaneseText>
      <EnglishText>Rubia</EnglishText>
      <Notes/>
      <Id>19</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エミル</JapaneseText>
      <EnglishText>Emil</EnglishText>
      <Notes/>
      <Id>22</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ごめんなさい。
私、誤解してたみたい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなに気にしなくていいって。
部屋の掃除を押しつけた
ルビアも悪いんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だから謝ってるじゃない。
ごめんね、エミル</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いいよ、べつに。
掃除とか、嫌いじゃないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう、エミル器大きすぎ！
そんなんだから
私心配しちゃうんだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え？　ご、ごめん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エミル。
オレでよければ、いつでも愚痴
聞いてやるからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ありがとう。
でも僕は大丈夫……かな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
