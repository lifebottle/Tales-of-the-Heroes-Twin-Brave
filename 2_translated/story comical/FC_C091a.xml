  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんでカイウスはそうなのよ！
無神経すぎ！</JapaneseText>
      <EnglishText>Why are you like this?!
You're so inconsiderate!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>少しはレディに対する扱いってものを
学んでくれてもいいんじゃないの！？</JapaneseText>
      <EnglishText>Can't you at least learn a LITTLE
on how to treat a lady?!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うるさいなぁ。
そんなんわからないよ</JapaneseText>
      <EnglishText>Oh, shut up.
I don't get stuff like that.</EnglishText>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わかろうともしてないくせに！</JapaneseText>
      <EnglishText>You don't even try to get it!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、まあまあ落ち着いて</JapaneseText>
      <EnglishText>C-Come on now, let's calm down here.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうよ、
いつかはわかってくれるわよ</JapaneseText>
      <EnglishText>She's right.
I'm sure he'll understand someday.</EnglishText>
      <Notes/>
      <SpeakerId>29</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うるさいわね！
なんなの、あなた達！</JapaneseText>
      <EnglishText>Shut up!
Besides, who the heck are you guys?!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あたし達の問題に口挟まないでよ！</JapaneseText>
      <EnglishText>Don't try to get involved in our problems!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>勝負よ！！！</JapaneseText>
      <EnglishText>Fight me!!!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ええぇ！？　どうして！？</JapaneseText>
      <EnglishText>HUH?! Why?!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
