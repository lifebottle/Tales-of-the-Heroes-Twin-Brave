      <SpeakerId>31</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん。
期待してたのはミラだけだと思うよ</JapaneseText>
