  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これで５人揃ったね、リアラ！</JapaneseText>
      <EnglishText>All 5 of us are here now, Reala!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まぁ楽しそうだし、おれはいいぜ！
これからよろしくな！</JapaneseText>
      <EnglishText>Well, this sounds fun, so I'm good with it!
Looking forward to working with you!</EnglishText>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>今回は諦めるけど
次メンバーを考えるときは
“桃色”としてあたしを呼んでね</JapaneseText>
      <EnglishText>I'll let it go this time, but whenever you
have to think about your next members,
be sure to call me to be "Pink".</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>呼ばないわ</JapaneseText>
      <EnglishText>We can't call you that.</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんでよ！！？</JapaneseText>
      <EnglishText>Why not?!!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>メンバーに“桃色”を入れるなら……</JapaneseText>
      <EnglishText>If anyone in the team was
called the "Pink" member...</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わたしが入るから！</JapaneseText>
      <EnglishText>I'd have to be part of the team!</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>えぇぇぇぇぇ！！！？</JapaneseText>
      <EnglishText>Whaaaaa?!!!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
