  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>よし、突破した！　逃げよう、コハク！</JapaneseText>
      <EnglishText>Alright, we broke through! Let's go, Kohaku!</EnglishText>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミソのついたクレープ！　ちゃんと食べてね！！</JapaneseText>
      <EnglishText>Crepe with miso! Be sure to savor it!!</EnglishText>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんだったんだ、あいつら？</JapaneseText>
      <EnglishText>What the heck is with her?</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>知るか！　僕に聞くな！</JapaneseText>
      <EnglishText>As if I care! Don't ask me!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ん？　このクレープについてるミソ……</JapaneseText>
      <EnglishText>This crepe with miso on it...</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうかしたのか？</JapaneseText>
      <EnglishText>Is something wrong?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……田楽ミソだ</JapaneseText>
      <EnglishText>...It's sweet miso glaze.</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一応……甘さを考慮したのか</JapaneseText>
      <EnglishText>Did she... at least take the
sweet part into consideration?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
