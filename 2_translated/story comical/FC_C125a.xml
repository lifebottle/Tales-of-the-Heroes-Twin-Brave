<SceneText>
  <FriendlyName>Chapter 5 (Flynn) - Start</FriendlyName>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>フレン</JapaneseText>
      <EnglishText>Flynn</EnglishText>
      <Notes/>
      <Id>25</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ユーリ</JapaneseText>
      <EnglishText>Yuri</EnglishText>
      <Notes/>
      <Id>24</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いい加減にしてくれ、ユーリ！</JapaneseText>
      <EnglishText>Knock it off already, Yuri!</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>君のせいで
僕の言葉はすべて説得力を失ってしまう！</JapaneseText>
      <EnglishText>Because of you, my words are
losing all of their persuasion!</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレのせいだってのかよ？</JapaneseText>
      <EnglishText>Why's that my fault?</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どう考えても君のせいだろ！</JapaneseText>
      <EnglishText>No matter how you look at this, it is your fault!</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だったら、どうするんだ？</JapaneseText>
      <EnglishText>So what are you gonna do about it?</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕は順序を間違っていたようだ</JapaneseText>
      <EnglishText>It seems I got the order of things wrong.</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>真っ先に更生させるべきは、君だった</JapaneseText>
      <EnglishText>You're the first one who needs to start anew.</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレがおとなしく
お前の言う事聞くとでも思ってんのか？</JapaneseText>
      <EnglishText>Do you actually think I'm just gonna quietly
listen to whatever it is you have to say?</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>思っていないさ。　だから……</JapaneseText>
      <EnglishText>I don't think you will. So...</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>想いは剣に乗せて……か</JapaneseText>
      <EnglishText>You're gonna put those feelings
into your sword... right?</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いいぜ。
かかってこいよ、フレン</JapaneseText>
      <EnglishText>Sounds good.
Come at me, Flynn.</EnglishText>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>容赦はしない……ユーリ！</JapaneseText>
      <EnglishText>I won't hold back... Yuri!</EnglishText>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
