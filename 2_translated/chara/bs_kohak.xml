<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Kohaku</JapaneseText>
      <EnglishText>Kohaku</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>すごい敵がいるみたい……</JapaneseText>
      <EnglishText>This is such a powerful enemy...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一人であの数を！？</JapaneseText>
      <EnglishText>Just the one by themselves?!</EnglishText>
      <Notes>Subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わたしじゃ勝てるかわからない……</JapaneseText>
      <EnglishText>I'm not sure I can win this...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>急いで止めなきゃ、大変な事になる！</JapaneseText>
      <EnglishText>I have to hurry and stop this, or it'll be terrible!</EnglishText>
      <Notes>Subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの動き、危険かも……</JapaneseText>
      <EnglishText>Those movement could be dangerous...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まだ続いてる？</JapaneseText>
      <EnglishText>This battle is still going?</EnglishText>
      <Notes>Battle is currently a guess at context.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>すごい。完全に圧倒してる……</JapaneseText>
      <EnglishText>Incredible. We've completely overpowered them...</EnglishText>
      <Notes>Subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなすごい実力だなんて……</JapaneseText>
      <EnglishText>To think they're this skilled...</EnglishText>
      <Notes>Subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>信じられない……</JapaneseText>
      <EnglishText>I can't believe it...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>勝てるのかな、わたし……</JapaneseText>
      <EnglishText>I wonder if I can win...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>許さない！　本気でいくよ！</JapaneseText>
      <EnglishText>I won't forgive you! I'm serious!</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>来るんだったら、覚悟はしてね</JapaneseText>
      <EnglishText>If you're attacking, prepare yourself.</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わたしの足技……味わってみる？</JapaneseText>
      <EnglishText>You ready... to taste my legwork?</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
</SceneText>
