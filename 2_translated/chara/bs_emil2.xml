  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もうあんなに倒してるなんて……</JapaneseText>
      <EnglishText>I can't believe I've already defeated this many...</EnglishText>
      <Notes>Unknown actual subject matter. (Could be "we", but I think it's "I".)</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんなに強い人と戦えるの？</JapaneseText>
      <EnglishText>Can I really fight someone so strong?</EnglishText>
      <Notes>Unknown actual subject matter. (Could be "we", but I think it's "I".)</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>誰にも止められないのに、僕なんかじゃ……</JapaneseText>
      <EnglishText>Nobody else can stop them, so I know I can't...</EnglishText>
      <Notes>First subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕じゃ勝てないかもしれないけど、やるしか……</JapaneseText>
      <EnglishText>I might not win, but I have to try...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの人、すごく動きがいいよ</JapaneseText>
      <EnglishText>That person moves really well.</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>戦わなきゃいけないの？　あんな強い人と……</JapaneseText>
      <EnglishText>Do I really have to fight?
And against someone so powerful...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>信じられないよ……</JapaneseText>
      <EnglishText>I can't believe it...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんなすごい人がいるなんて……</JapaneseText>
      <EnglishText>To think there's such an amazing person...</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>誰かが止めなきゃ、もっと大変な事になる</JapaneseText>
      <EnglishText>If someone doesn't stop them, it'll be terrible.</EnglishText>
      <Notes>Subject.</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんな人と戦って、僕は勝てるの？</JapaneseText>
      <EnglishText>Can I win against a person like that?</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ゆ、許さないぞ！</JapaneseText>
      <EnglishText>I-I won't forgive you!</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やっぱり退いてはくれないんだね……</JapaneseText>
      <EnglishText>So they're not gonna retreat...</EnglishText>
      <Notes>Subject. Could be "you're", "she" or "he".</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕がエミルだ。僕だって……やれるはず！</JapaneseText>
      <EnglishText>I'm Emil. I can... do this, too!</EnglishText>
      <Notes/>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
