  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まったく！
他人のくせにあたし達の事に
口を挟まないでほしいわよね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレ達のケンカを
止めようとしてくれたんじゃないかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんな必要ないわ！
カイウスがちゃんとすれば
いいだけの話だもの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ちゃんとねえ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
