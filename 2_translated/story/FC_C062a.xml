  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さっきの女の子二人組、見たか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……いや</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>片方は足が丸見えで
もう片方は身体のラインが
くっきり見える服装だった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>若い女の子があんな格好してたら
いつ犯罪に巻き込まれるかわからねぇ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>彼女達の為に、警告してやろう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
