    <Entry>
      <PointerOffset/>
      <JapaneseText>ハァ……。
まさかエビの為に
世界樹まで来る事になるなんてよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……うん、僕も考えもしなかったよ。
ガイの言ってた『ある場所』が
世界樹だったなんて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でもとにかくいこう。
ガイにエビを届けるために</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まためんどくせェ事に
なんなきゃいいけどな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>21</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
