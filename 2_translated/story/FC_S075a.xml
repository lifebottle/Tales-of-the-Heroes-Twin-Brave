<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>クロエ</JapaneseText>
      <EnglishText>Chloe</EnglishText>
      <Notes/>
      <Id>15</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>セネル</JapaneseText>
      <EnglishText>Senel</EnglishText>
      <Notes/>
      <Id>14</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>人の命を犠牲にする事で
新たな命を創り出す魔剣</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>死んだ者すらも創り出せる力……か</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなもの、使っていいはずがない。
誰かを犠牲にして命を生み出すなど
あってはならない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>クロエ？
聞いてるのか、クロエ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え、あ、え！？
どうした、クーリッジ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なにボサッとしてるんだ？
やっとデュークに追いついたんだぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>魔剣エターナルソードなんて
絶対に使わせるわけにはいかない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あ、ああ。
もちろんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
