<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>セネル</JapaneseText>
      <EnglishText>Senel</EnglishText>
      <Notes/>
      <Id>14</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>クロエ</JapaneseText>
      <EnglishText>Chloe</EnglishText>
      <Notes/>
      <Id>15</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……終わったか</JapaneseText>
      <EnglishText>...Is it over now?</EnglishText>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>すまない、クロエ。
いつも俺のせいで
戦いに巻き込んでしまって</JapaneseText>
      <EnglishText>Sorry, Chloe.
You kept getting caught up in
fights because I kept screwing up.</EnglishText>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いや、いいんだ。
私は私の意志でクーリッジに
手を貸しているのだからな</JapaneseText>
      <EnglishText>No, it's alright.
I've been offering you my help of my own free will.</EnglishText>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうか、ありがとう</JapaneseText>
      <EnglishText>Gotcha. Thanks.</EnglishText>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その……クーリッジ。
一つ相談なのだが……</JapaneseText>
      <EnglishText>Um, Coolidge.
There's something I want to talk to you about.</EnglishText>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなに朝起きられないなら
私が毎日起こしにいってもいいのだぞ？</JapaneseText>
      <EnglishText>If it's that hard for you to get up
in the morning, would it be alright
if I came to wake you up everyday?</EnglishText>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……ああ、うん……</JapaneseText>
      <EnglishText>...Uh, yeah...</EnglishText>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……クーリッジ？</JapaneseText>
      <EnglishText>...Coolidge?</EnglishText>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……悪い、寝たりないみたいだ。　帰って寝る</JapaneseText>
      <EnglishText>...Sorry. Seems like I didn't get enough sleep.
I'm gonna head on home.</EnglishText>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そ、そうか……</JapaneseText>
      <EnglishText>I-I see...</EnglishText>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
