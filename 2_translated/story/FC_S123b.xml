<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ユーリ</JapaneseText>
      <EnglishText>Yuri</EnglishText>
      <Notes/>
      <Id>24</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>フレン</JapaneseText>
      <EnglishText>Flynn</EnglishText>
      <Notes/>
      <Id>25</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、一応礼は言っとくぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>素直じゃないな、君は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>本当にいいのか？
お偉い騎士様が罪人の側なんかにいてもよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なにを言っているんだ。
罪人が逃げないように見張っている事に
なんら問題はないだろう？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ああ、なるほどな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それに、僕も君と同じ考えさ。
エターナルソードの時を越える力は危険だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強力すぎる力を求めて
いつまたあの役人のような人間が
現れてもおかしくない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やはり破壊しておくべきだと
……僕もそう思う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なら、一時休戦ってとこだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうだね。
そういう事にしておいてくれるかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
