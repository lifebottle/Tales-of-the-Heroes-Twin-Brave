  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう！
カイウスがちゃんとしないから
みんなに勘違いされるんじゃない！</JapaneseText>
      <EnglishText>Honestly! If you just did things the right way,
everyone wouldn't be getting these
misunderstandings with us!</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>お、オレのせいなのか！？</JapaneseText>
      <EnglishText>Th-This is MY fault?!</EnglishText>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうよ！
ぜーーんぶ、カイウスが悪いの</JapaneseText>
      <EnglishText>That's right!
Aaaaall of this is your fault.</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひでぇな……</JapaneseText>
      <EnglishText>You're horrible...</EnglishText>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>諦めなさいよ</JapaneseText>
      <EnglishText>Just give up already.</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あたし達、これからもずっと
このままなんだから</JapaneseText>
      <EnglishText>We're aaalways gonna be like this.</EnglishText>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
