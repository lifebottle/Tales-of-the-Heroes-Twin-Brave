    <Entry>
      <PointerOffset/>
      <JapaneseText>カイウス</JapaneseText>
      <EnglishText>Caius</EnglishText>
      <Notes/>
      <Id>18</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マルタ</JapaneseText>
      <EnglishText>Marta</EnglishText>
      <Notes/>
      <Id>23</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エミル</JapaneseText>
      <EnglishText>Emil</EnglishText>
      <Notes/>
      <Id>22</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう、カイウスのバカ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっとレディを扱うように
ちゃんとエスコートしてよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>レディって言われてもな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>18</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ねぇねぇエミル〜、今の聞いた？
女の子はやっぱりエスコートされたいよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その点うちのエミルは
カッコイイ上にエスコートも完璧！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう！　素敵すぎるよ、エミル！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え、そ、そうかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なによ！！
カイウスだって、不器用なだけで
ホントは優しいとこもあるんだから！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう決闘よ！！
カイウスがあなたのエミルなんかに
負けるもんですか！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
