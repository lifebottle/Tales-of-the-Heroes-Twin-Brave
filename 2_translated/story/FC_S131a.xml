<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>コハク</JapaneseText>
      <EnglishText>Kohaku</EnglishText>
      <Notes/>
      <Id>27</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>シング</JapaneseText>
      <EnglishText>Shing</EnglishText>
      <Notes/>
      <Id>26</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>街へ行けば、きっとなにかわかるはず。
マナの枯渇を止める方法も
きっと見つかるよね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうだね、悩んでたって始まらない！
とにかくガンドコ行こう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ふぅ、やっぱり街までけっこうあるね。
ちょっと疲れちゃった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そう？　わたしは全然平気かな。
毎朝、家の裏山のてっぺんまで走ってるし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>裏山のてっぺん！？
あの山って確か…普通に登ったら
１日かかるんじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>子供の頃から日課にしてるから、
午前中に５往復くらいなら余裕かな。
慣れちゃえば簡単よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>…（コハクの脚は相変わらず凄いなぁ）</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>コハク！　あれを見て！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あ、女の人が追われてる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>男２人で女の人を襲うなんて
どんな事情があっても見過ごせない！
助けよう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>26</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
