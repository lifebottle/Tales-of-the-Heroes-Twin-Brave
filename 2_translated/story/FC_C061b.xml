  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>更生完了！　今日も星三つだぜ！</JapaneseText>
      <EnglishText>Rehab complete! Another three stars for today!</EnglishText>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>べつに俺達は不良じゃないぞ</JapaneseText>
      <EnglishText>We're not even delinquents, though.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうだよ！</JapaneseText>
      <EnglishText>Yeah!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>悪かったよ。
見た目はともかく
確かに二人とも中身はまともみたいだな</JapaneseText>
      <EnglishText>Sorry 'bout that. Appearances aside,
you two do seem like decent folks.</EnglishText>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でも誤解されないように
やっぱり髪の毛は切った方がいいぜ！</JapaneseText>
      <EnglishText>But if you wanna avoid misunderstandings,
you really should cut your hair!</EnglishText>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だからティトレイさんの方が長いじゃないか</JapaneseText>
      <EnglishText>But your hair is long, too.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>しかも珍しいくらいの緑だしな。
金髪なんて可愛い方だと思うけどなぁ</JapaneseText>
      <EnglishText>It's a rare shade of green, too.
I think blond hair is charming, though.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>緑は大自然の色だからいいんだ！</JapaneseText>
      <EnglishText>Green is nice 'cause it's the color of nature itself!</EnglishText>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それどんな理屈！？</JapaneseText>
      <EnglishText>What's with that logic?!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ピーチパイはまだか……</JapaneseText>
      <EnglishText>Is my peach pie still not ready yet...?</EnglishText>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
