<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>リアラ</JapaneseText>
      <EnglishText>Reala</EnglishText>
      <Notes/>
      <Id>9</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>カイル</JapaneseText>
      <EnglishText>Kyle</EnglishText>
      <Notes/>
      <Id>8</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>カイル、わたしもう迷わない</JapaneseText>
      <EnglishText>Kyle, I won't hesitate anymore.</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わたしはカイルと一緒にいたい。
あなたを消したくなんかない</JapaneseText>
      <EnglishText>I want to be with you.
I don't want you to be erased.</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でも……逃げちゃいけないのね
だってここで逃げたら
カイルは英雄じゃなくなってしまう</JapaneseText>
      <EnglishText>But... I can't run away from this.
If I do, you won't be a hero anymore.</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>リアラ……</JapaneseText>
      <EnglishText>Reala...</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わたしが信じて
カイルがその道を切り開いてくれる。
それがわたしの英雄……カイルだもんね</JapaneseText>
      <EnglishText>I believe in you, and I know you'll carve out a path.
That's how my hero is... That's how you are, Kyle.</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん、そうだよ！</JapaneseText>
      <EnglishText>Yeah, that's right!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>行きましょう、エルレインのもとへ……</JapaneseText>
      <EnglishText>Let's go. To where Elraine is...</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
