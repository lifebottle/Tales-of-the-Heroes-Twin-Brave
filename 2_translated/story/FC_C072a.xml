  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あなたが寝坊して
船を出してくれなかったせいで
頼まれたホットドッグが買えなかったよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうしてくれるのさ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>おい、お前！
俺が乗るはずだった船を
出航させないなんて、どういうつもりだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺を誰だと思ってんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……知るか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>クーリッジ！
お前の寝坊で船を逃した相手に対して
それはあまりにも失礼だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>15</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>てめぇ……許せねぇ！
痛い目見してやっからな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ほ、ホットドッグの
責任とってもらうからね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>20</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
