<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>フレン</JapaneseText>
      <EnglishText>Flynn</EnglishText>
      <Notes/>
      <Id>25</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ユーリ</JapaneseText>
      <EnglishText>Yuri</EnglishText>
      <Notes/>
      <Id>24</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>君の言う事もわかる。
悪事を働いた人間になんの罰も与えず
無罪放免になどしていいはずがない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>だがやはり罪人は法に裁かれるべきなんだ。
個人が人に罰を与える事は
決して許されない……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その法が裁けなかったから
あいつは釈放されたんだろうが……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それが正しい事だとは言っていない！
しかし法が間違っているのなら
まず法を正す事が先決だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>法を正す？
そりゃいつ出来るんだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いつか法を正すから
今は文句言わずに死ねって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そう言うのか、お前は……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうは言っていない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もう行くぜ。
これ以上話しててもラチがあかねぇよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げるのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……今はな。
まだ捕まってやるわけにはいかねぇんだ。
オレには、やらなきゃいけねぇ事がある</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やらなきゃいけない事？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレは……エターナルソードを破壊する</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
