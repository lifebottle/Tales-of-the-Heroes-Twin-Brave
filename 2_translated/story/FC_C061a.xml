      <SpeakerId>13</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>……べつに</JapaneseText>
      <EnglishText>...Not really.</EnglishText>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>思うよな！　やっぱり思うよな！
よーし、注意しにいこうぜ！</JapaneseText>
      <EnglishText>You do! You absolutely do!
Alriiight! Let's go tell 'em off!</EnglishText>
