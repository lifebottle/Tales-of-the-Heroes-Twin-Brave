<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミラ</JapaneseText>
      <EnglishText>Milla</EnglishText>
      <Notes/>
      <Id>31</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エミル</JapaneseText>
      <EnglishText>Emil</EnglishText>
      <Notes/>
      <Id>22</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マルタ</JapaneseText>
      <EnglishText>Marta</EnglishText>
      <Notes/>
      <Id>23</Id>
      <Status>Done</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ジュード</JapaneseText>
      <EnglishText>Jude</EnglishText>
      <Notes/>
      <Id>30</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うむ。　これでひとまず安心だろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>腕輪をつけている限り
ラタトスクに人格を奪われることも
ないはずだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ではジュード。
私達はそろそろ行こうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの、ミラさんたちはどこに行くんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹のもとに向かう。
マナの枯渇を防ぎ、世界を救うために</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界を……救う？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>それが私の使命だからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕はそのお手伝い。
ミラみたいな立派な使命感とかはないけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>でも、自分に出来ることをしたいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>私も一緒に行っていいですか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マルタ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>私今までずっと
もうひとりのエミルに守ってもらったのに
最後にあんなひどいことしちゃって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>償いになんかならないのはわかってる。
でも、なにかしたいの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わかった。　仲間として、歓迎しよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あ、ありがとうございます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕も行っていいですか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なんにもできないのはわかってます。
けど……それでも行きたいんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マルタの側に……いたいんです……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>エミル……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もちろん歓迎するよ。
いいよね、ミラ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>30</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>無論だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>31</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ありがとうございます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一緒に行こう、エミル</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん、最後までね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
