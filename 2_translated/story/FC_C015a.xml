      <SpeakerId>5</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>はぁ？　ふざけんなよ！</JapaneseText>
