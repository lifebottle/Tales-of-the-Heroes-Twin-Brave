      <SpeakerId>3</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ふざけんなよって膝蹴んなよ！</JapaneseText>
