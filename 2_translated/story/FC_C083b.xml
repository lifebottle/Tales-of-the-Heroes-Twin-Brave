  </Speakers>
  <Strings>
    <Section>Main Text</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あー。
なんかイケてる肉食いたくなっちまったな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ミソとピーチパイも食ってみたらどうだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>17</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわっ、なんだよ！
ミソってうめぇじゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こっちのピーチパイも甘くてうめぇ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>16</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>食わず嫌い……というか
食べた事なくて偏見持ってるだけだったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ピーチパイなしで育ったのか。
……気の毒な奴だな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>本当にすまなかったな。
たぶんもうミソとピーチパイの悪口は
言わないはずだから、許してやってくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>17</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん、いいよ！
ミソ好きになってくれたなら
もうわたし達、友達だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>27</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ピーチパイ好きに……悪い奴はいない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>おたくらはちょっと、好きすぎるけどな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>17</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
